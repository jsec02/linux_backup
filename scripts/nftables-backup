#!/usr/bin/env bash

# ================================================================================
# =                              NFTABLES-BACKUP                                 =
# ================================================================================

# Collect nftables configs from all systems and backup to restic
# - ArchLinux WSL: local /etc/nftables.conf
# - Debian Pi: remote /etc/nftables.conf
# - Kali VM: remote /etc/nftables.conf
# - RHEL VM: remote /etc/sysconfig/nftables.conf
# - Backs up to local Pi (R1) and cloud B2 (R2)
# - Prunes old snapshots, keeping last 1

set -euo pipefail

VBOXMANAGE="/mnt/c/Program Files/Oracle/VirtualBox/VBoxManage.exe"

BACKUP_DIR=~/temp/nftables
mkdir -p "$BACKUP_DIR"

backup_vm_nftables() {
  local vm_name=$1
  local ssh_host=$2
  local nft_path=${3:-/etc/nftables.conf}
  local was_running=false
  local state
  state=$("$VBOXMANAGE" showvminfo "$vm_name" --machinereadable 2>/dev/null | grep "VMState=" | cut -d'"' -f2)
  if [ "$state" = "running" ]; then
    was_running=true
  else
    echo "  → Starting $vm_name..."
    "$VBOXMANAGE" startvm "$vm_name" --type headless
    until ssh -o ConnectTimeout=2 -o StrictHostKeyChecking=no "$ssh_host" "exit" 2>/dev/null; do
      sleep 2
    done
  fi
  echo "  → Collecting nftables.conf from $vm_name..."
  mkdir -p "$BACKUP_DIR/$ssh_host"
  ssh "$ssh_host" "cat $nft_path" >"$BACKUP_DIR/$ssh_host/nftables.conf"
  if [ "$was_running" = false ]; then
    echo "  → Shutting down $vm_name..."
    "$VBOXMANAGE" controlvm "$vm_name" acpipowerbutton
  fi
}
echo "Collecting nftables configs..."

# --- 1. ArchLinux WSL (local) ---
echo "  → ArchLinux WSL..."
mkdir -p "$BACKUP_DIR/archwsl"
cat /etc/nftables.conf >"$BACKUP_DIR/archwsl/nftables.conf"

# --- 2. Debian Pi (remote SSH) ---
echo "  → Debian Pi..."
mkdir -p "$BACKUP_DIR/pi"
ssh pi "cat /etc/nftables.conf" >"$BACKUP_DIR/pi/nftables.conf"

# --- 3. Kali VM ---
echo "  → Kali VM..."
backup_vm_nftables "kalivm" "kali"

# --- 4. RHEL VM ---
echo "  → RHEL VM..."
backup_vm_nftables "rhelvm" "rhel" "/etc/sysconfig/nftables.conf"

# --- 5. Backup to restic ---
echo "Backing up to restic..."
restic -r "$R1" backup "$BACKUP_DIR" --tag nftables
restic -r "$R2" backup "$BACKUP_DIR" --tag nftables

# --- 6. Prune old snapshots ---
echo "Pruning old snapshots..."
restic -r "$R1" forget --tag nftables --keep-last 1 --prune
restic -r "$R2" forget --tag nftables --keep-last 1 --prune

# --- 7. Clean up ---
rm -rf "$BACKUP_DIR"
echo "nftables configs backed up successfully"
