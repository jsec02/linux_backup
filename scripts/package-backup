#!/usr/bin/env bash

# ================================================================================
# =                                PACKAGE-BACKUP                                =
# ================================================================================

# Collect package lists from all systems and backup to restic
# - ArchLinux WSL: yay, uv, npm packages
# - Windows: winget packages
# - Debian Pi: apt packages
# - Kali VM: apt packages
# - RHEL VM: dnf packages

# - Backs up to local Pi (R1) and cloud B2 (R2)
# - Prunes old snapshots, keeping last 1

set -euo pipefail

VBOXMANAGE="/mnt/c/Program Files/Oracle/VirtualBox/VBoxManage.exe"

# Setup temp directory
PKG_DIR=~/temp
mkdir -p "$PKG_DIR"

# Starts VM if not running, collects packages, shuts down only if we started it
backup_vm_packages() {
  local vm_name=$1
  local ssh_host=$2
  local pkg_cmd=$3
  local output_file=$4
  local was_running=false
  local state
  state=$("$VBOXMANAGE" showvminfo "$vm_name" --machinereadable 2>/dev/null | grep "VMState=" | cut -d'"' -f2)
  if [ "$state" = "running" ]; then
    was_running=true
  else
    echo "  → Starting $vm_name..."
    "$VBOXMANAGE" startvm "$vm_name" --type headless
    until ssh -o ConnectTimeout=2 -o StrictHostKeyChecking=no "$ssh_host" "exit" 2>/dev/null; do
      sleep 2
    done
  fi
  echo "  → Collecting packages from $vm_name..."
  ssh "$ssh_host" "$pkg_cmd" >"$output_file"
  if [ "$was_running" = false ]; then
    echo "  → Shutting down $vm_name..."
    "$VBOXMANAGE" controlvm "$vm_name" acpipowerbutton
  fi
}

echo "Collecting package lists..."

# --- 1. ArchLinux WSL (local) ---
echo "  → ArchLinux packages (yay)..."
yay -Qqe >"$PKG_DIR/arch_wsl_yay.txt"

echo "  → ArchLinux packages (uv)..."
UV_FILE="$PKG_DIR/arch_wsl_uv.txt"
>"$UV_FILE"

# Main environment
echo "# main" >>"$UV_FILE"
uv pip freeze >>"$UV_FILE"
echo "" >>"$UV_FILE"

# UV tools
echo "# uv tools" >>"$UV_FILE"
uv tool list >>"$UV_FILE"
echo "" >>"$UV_FILE"

# Virtual environments
VENV_ROOT=~/venvs
if [ -d "$VENV_ROOT" ]; then
  for venv_path in "$VENV_ROOT"/*; do
    if [ -d "$venv_path/bin" ]; then
      venv_name=$(basename "$venv_path")
      echo "# $venv_name" >>"$UV_FILE"
      source "$venv_path/bin/activate"
      uv pip freeze >>"$UV_FILE"
      echo "" >>"$UV_FILE"
      deactivate
    fi
  done
fi

echo "  → ArchLinux packages (npm)..."
npm ls -g --depth=0 --parseable | tail -n +2 | xargs -n1 basename >"$PKG_DIR/arch_wsl_npm.txt"

# --- 2. Windows (via PowerShell from WSL) ---
echo "  → Windows packages (winget)..."
powershell.exe -Command "winget export --ignore-warnings -o $PKG_DIR/windows_desktop_winget.json"

# --- 3. Debian Pi (remote SSH) ---
echo "  → Debian Pi packages (apt)..."
ssh pi "apt-mark showmanual" >"$PKG_DIR/debian_pi_apt.txt"

# --- 4. Kali VM ---
echo "  → Kali VM packages (apt)..."
backup_vm_packages "kalivm" "kali" "apt-mark showmanual" "$PKG_DIR/kali_apt.txt"

# --- 5. RHEL VM ---
echo "  → RHEL VM packages (dnf)..."
backup_vm_packages "rhelvm" "rhel" "dnf repoquery --userinstalled --queryformat '%{name}' | grep -v 'Not root'" "$PKG_DIR/rhel_dnf.txt"

# --- 6. Backup to restic ---
echo "Backing up to restic..."
restic -r "$R1" backup "$PKG_DIR" --tag packages
restic -r "$R2" backup "$PKG_DIR" --tag packages

# --- 7. Prune old snapshots ---
echo "Pruning old snapshots..."
restic -r "$R1" forget --tag packages --keep-last 1 --prune
restic -r "$R2" forget --tag packages --keep-last 1 --prune

# --- 8. Clean up ---
rm -rf "$PKG_DIR"
echo "Package lists backed up successfully"
