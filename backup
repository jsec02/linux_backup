backup_zsh() {
    local DST_DIR="/tmp/zsh"

    mkdir --parents "$DST_DIR"

    # Collect .zshrc
    local ZSHRC="$HOME/.zshrc"

    if [[ -f "$ZSHRC" ]]; then
        echo "Collecting .zshrc..."
        rsync --archive --verbose --copy-links "$ZSHRC" "$DST_DIR"
    fi

    # Collect .zshenv
    local ZSHENV="$HOME/.zshenv"

    if [[ -f "$ZSHENV" ]]; then
        echo "Collecting .zshenv..."
        rsync --archive --verbose --copy-links "$ZSHENV" "$DST_DIR"
    fi

    # Collect .zshenv.local
    local ZSHENV_LOCAL="$HOME/.zshenv.local"

    if [[ -f "$ZSHENV_LOCAL" ]]; then
        echo "Collecting .zshenv.local..."
        rsync --archive --verbose --copy-links "$ZSHENV_LOCAL" "$DST_DIR"
    fi

    # Backup
    restic_backup "$DST_DIR" zsh 1

    # Cleanup
    rm --recursive --force "$DST_DIR"
}

backup() {
    local targets=("${@:-all}")

    if [[ "${targets[0]}" == "all" ]]; then
        backup_vault
        backup_python
        backup_bash
        backup_powershell
        backup_sql
        backup_nvim
        backup_zellij
        backup_helix
        backup_kakoune
        backup_ssh
        backup_direnv
        backup_sqliterc
        backup_databases
        backup_nftables
        backup_history
        backup_wsl
        backup_wt
        backup_zsh
        return
    fi

    for target in "${targets[@]}"; do
        local function="backup_$target"

        if ! declare -f "$function" >/dev/null; then
            echo "Unknown target: $target" >&2
            exit 1
        fi

        "$function"
    done
}

backup_integrity() {
    for repo in "${REPOSITORIES[@]}"; do
        restic --repo "$repo" check --read-data-subset=5%
    done
}

backup_stats() {
    for repo in "${REPOSITORIES[@]}"; do
        restic --repo "$repo" stats --mode=raw-data
    done
}

main() {
    local cmd="${1:-backup}"
    shift

    case "$cmd" in
        backup) backup "$@" ;;
        integrity) backup_integrity ;;
        stats) backup_stats ;;
        *)
            echo "$(basename "$0") usage: {backup|integrity|stats}"
            exit 1
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
