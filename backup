backup_wsl() {
    local DST_DIR="/tmp/wsl"

    # Collect from wsl
    local WSL_SRC_FILE="/etc/wsl.conf"
    local WSL_DST_DIR="$DST_DIR/wsl"

    mkdir --parents "$WSL_DST_DIR"

    if [[ -f "$WSL_SRC_FILE" ]]; then
        echo "Collecting wsl wsl.conf..."
        rsync --archive --verbose --copy-links "$WSL_SRC_FILE" "$WSL_DST_DIR"
    fi

    # Collect from windows
    local WINDOWS_SRC_FILE="$WIN_HOME/.wslconfig"
    local WINDOWS_DST_DIR="$DST_DIR/windows"

    mkdir --parents "$WINDOWS_DST_DIR"

    if [[ -f "$WINDOWS_SRC_FILE" ]]; then
        echo "Collecting windows .wslconfig..."
        rsync --archive --verbose --copy-links "$WINDOWS_SRC_FILE" "$WINDOWS_DST_DIR"
