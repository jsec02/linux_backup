#!/usr/bin/env bash

# ================================================================================
# =                                    BACKUP                                    =
# ================================================================================

# Backup notes, code, configuration files, packages, and databases
# - Collects from wsl, windows, and pi
# - Sends to local pi (R1) and cloud B2 (R2) Restic repositories
# - Prunes old snapshots, keeping last 1 or 7

REPOSITORIES=("$R1" "$R2")

PI="master@10.0.0.181"

PI_HOME="/home/master"
WIN_HOME="/mnt/c/Users/master"

restic_backup() {
    local path="$1"
    local tag="$2"
    local keep="$3"

    for repo in "${REPOSITORIES[@]}"; do
        restic --repo "$repo" backup "$path" --tag "$tag"
        restic --repo "$repo" forget --tag "$tag" --keep-last "$keep" --prune
        echo "Backed up and pruned $tag in $repo"
    done
}

backup_vault() { restic_backup "$HOME/vault" vault 7; }
backup_python() { restic_backup "$HOME/python" python 7; }
backup_bash() { restic_backup "$HOME/bash" bash 7; }
backup_powershell() { restic_backup "$HOME/powershell" powershell 7; }
backup_sql() { restic_backup "$HOME/sql" sql 7; }
backup_nvim() { restic_backup "$HOME/.config/nvim" nvim 7; }
backup_zellij() { restic_backup "$HOME/.config/zellij" zellij 7; }
backup_wt() { restic_backup "$WIN_HOME/AppData/Local/Packages/Microsoft.WindowsTerminal_8wekyb3d8bbwe/LocalState/settings.json" wt 1; }
backup_helix() { restic_backup "$HOME/.config/helix" helix 7; }
backup_kakoune() { restic_backup "$HOME/.config/kak" kakoune 7; }
backup_direnv() { restic_backup "$HOME/.config/direnv" direnv 7; }
backup_sqliterc() { restic_backup "$HOME/.sqliterc" sqliterc 1; }

backup_databases() {
    local DST_DIR="/tmp/databases"

    # Collect from wsl
    local WSL_SRC_DIR="$HOME/databases"
    local WSL_DST_DIR="$DST_DIR/wsl"

    mkdir --parents "$WSL_DST_DIR"

    if [[ -d "$WSL_SRC_DIR" ]]; then
        echo "Collecting wsl databases..."
        rsync --archive --verbose --copy-links "$WSL_SRC_DIR" "$WSL_DST_DIR"
    fi

    # Collect from pi
    local PI_SRC_DIR="$PI_HOME/databases"
    local PI_DST_DIR="$DST_DIR/pi"

    mkdir --parents "$PI_DST_DIR"

    # shellcheck disable=SC2029
    if ssh "$PI" "[[ -d $PI_SRC_DIR ]]"; then
        echo "Collecting pi databases..."
        rsync --archive --verbose --copy-links "$PI:$PI_SRC_DIR" "$PI_DST_DIR"
    fi

    # Backup
    restic_backup "$DST_DIR" databases 7

    # Cleanup
    rm --recursive --force "$DST_DIR"
}

backup_ssh() {
    local DST_DIR="/tmp/ssh"
    local SRC_DIR="$HOME/.ssh"

    mkdir --parents "$DST_DIR"

    # Collect config
    local CONFIG="$SRC_DIR/config"

    if [[ -f "$CONFIG" ]]; then
        echo "Collecting ssh config..."
        rsync --archive --verbose --copy-links "$CONFIG" "$DST_DIR"
    fi

    # Collect private key
    local PRIVATE_KEY="$SRC_DIR/id_ed25519"

    if [[ -f "$PRIVATE_KEY" ]]; then
        echo "Collecting private key..."
        rsync --archive --verbose --copy-links "$PRIVATE_KEY" "$DST_DIR"
    fi

    # Collect private key
    local PUBLIC_KEY="$SRC_DIR/id_ed25519.pub"

    if [[ -f "$PUBLIC_KEY" ]]; then
        echo "Collecting public key..."
        rsync --archive --verbose --copy-links "$PUBLIC_KEY" "$DST_DIR"
    fi

    # Backup
    restic_backup "$DST_DIR" ssh 1

    # Cleanup
    rm --recursive --force "$DST_DIR"
}

