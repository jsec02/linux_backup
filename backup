#!/usr/bin/env bash

# ================================================================================
# =                                    BACKUP                                    =
# ================================================================================

# Backup notes, code, configuration files, and databases
# - Sends to local pi (R1) and cloud B2 (R2) Restic repositories
# - Prunes old snapshots, keeping last 1 or 7

REPOSITORIES=("$R1" "$R2")

WIN_HOME="/mnt/c/Users/master"

restic_backup() {
    local tag="$1"
    local keep="$2"

    shift 2

    local paths=()
    for path in "$@"; do
        # If path exists on system, append to paths array
        [[ -e "$path" ]] && paths+=("$path")
    done
    # If paths array is empty, return early
    ((${#paths[@]} == 0)) && return

    for repo in "${REPOSITORIES[@]}"; do
        restic --repo "$repo" backup "${paths[@]}" --tag "$tag"
        restic --repo "$repo" forget --tag "$tag" --host "$HOSTNAME" --keep-last "$keep" --prune
    done
}

backup_vault() { restic_backup vault 7 "$HOME/vault"; }
backup_python() { restic_backup python 7 "$HOME/python"; }
backup_bash() { restic_backup bash 7 "$HOME/bash"; }
backup_powershell() { restic_backup powershell 7 "$HOME/powershell"; }
backup_sql() { restic_backup sql 7 "$HOME/sql"; }
backup_dotfiles() { restic_backup dotfiles 7 "$HOME/dotfiles"; }
backup_nvim() { restic_backup nvim 7 "$HOME/.config/nvim"; }
backup_yazi() { restic_backup yazi 7 "$HOME/.config/yazi"; }
backup_packages() { restic_backup packages 1 "$HOME/packages"; }
backup_wireguard() { restic_backup wireguard 1 "/etc/wireguard"; }
backup_lightdm() { restic_backup lightdm 1 "/etc/lightdm/lightdm.conf"; }
backup_navidrome() { restic_backup navidrome 1 "/etc/navidrome/navidrome.toml"; }
backup_autostart() { restic_backup autostart 1 "$HOME/.config/autostart/deskflow.desktop" "$HOME/.config/autostart/redshift.desktop"; }
backup_redshift() { restic_backup redshift 1 "$HOME/.config/redshift"; }
backup_zellij() { restic_backup zellij 7 "$HOME/.config/zellij"; }
backup_wt() { restic_backup wt 1 "$WIN_HOME/AppData/Local/Packages/Microsoft.WindowsTerminal_8wekyb3d8bbwe/LocalState/settings.json"; }
backup_helix() { restic_backup helix 7 "$HOME/.config/helix"; }
backup_kakoune() { restic_backup kakoune 7 "$HOME/.config/kak"; }
backup_direnv() { restic_backup direnv 7 "$HOME/.config/direnv"; }
backup_git() { restic_backup git 1 "$HOME/.gitconfig"; }
backup_sqliterc() { restic_backup sqliterc 1 "$HOME/.sqliterc"; }
backup_databases() { restic_backup databases 7 "$HOME/databases"; }
backup_services() { restic_backup services 1 "/etc/systemd/system/riven-sniper.service" "/etc/systemd/system/qbittorrent-nox.service"; }
backup_ssh() { restic_backup ssh 1 "$HOME/.ssh"; }
backup_nftables() { restic_backup nftables 1 "/etc/nftables.conf"; }
backup_history() { restic_backup history 1 "$HOME/.zsh_history"; }
backup_wsl() { restic_backup wsl 1 "/etc/wsl.conf" "$WIN_HOME/.wslconfig"; }
backup_zsh() { restic_backup zsh 1 "$HOME/.zshrc" "$HOME/.zshenv" "$HOME/.zshenv.local" "$HOME/.zprofile"; }

backup() {
    local targets=("${@:-all}")

    if [[ "${targets[0]}" == "all" ]]; then
        backup_vault
        backup_python
        backup_bash
        backup_powershell
        backup_sql
        backup_dotfiles
        backup_nvim
        backup_lightdm
        backup_autostart
        backup_navidrome
        backup_redshift
        backup_yazi
        backup_packages
        backup_wireguard
        backup_zellij
        backup_helix
        backup_kakoune
        backup_ssh
        backup_direnv
        backup_sqliterc
        backup_databases
        backup_services
        backup_nftables
        backup_history
        backup_wsl
        backup_wt
        backup_zsh

        return
    fi

    for target in "${targets[@]}"; do
        local fn="backup_$target"

        # Check if function exists
        if ! declare -f "$fn" >/dev/null; then
            echo "Unknown target: $target" >&2
            exit 1
        fi

        "$fn"
    done
}

backup_integrity() {
    for repo in "${REPOSITORIES[@]}"; do
        restic --repo "$repo" check --read-data-subset=5%
    done
}

backup_stats() {
    for repo in "${REPOSITORIES[@]}"; do
        restic --repo "$repo" stats --mode=raw-data
    done
}

main() {
    local cmd="${1:-backup}"
    shift

    case "$cmd" in
        backup) backup "$@" ;;
        integrity) backup_integrity ;;
        stats) backup_stats ;;
        *)
            echo "$(basename "$0") usage: {backup|integrity|stats}"
            exit 1
            ;;
    esac
}

main "$@"
